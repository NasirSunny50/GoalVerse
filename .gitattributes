# Normalize text line endings across platforms
* text=auto

# Shell scripts & container entrypoints MUST stay LF — CRLF breaks the
# shebang inside Linux containers ("exec ...: no such file or directory").
*.sh                text eol=lf
docker-entrypoint.sh text eol=lf

# Binary assets — never apply EOL conversion (would corrupt them)
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.dll   binary
*.so    binary
*.dylib binary
*.exe   binary
*.apk   binary
*.aab   binary
*.jar   binary
*.keystore binary
*.jks   binary
*.db    binary
*.otf   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
